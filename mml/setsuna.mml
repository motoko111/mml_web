// Pulse
@[pulse]
t307 l4 o4 q50 v50 @1 @e[0,0.1,0.6,0.2] @m0
//@[sample]
//t307 l4 o4 q50 v400 @5 @e[0,0.4,1.0,0.5] @m0
/:r:/16
/:
q50
//C1=[ef+a]
//C2=[f+a>c+<]
//C3=[g+b>d<]
//C4=[a>c+e<]
//C5=[b>df+<]
//C6=[>c+eg+<]
//C7=[>df+a<]
C1=[ef+]
C2=[f+c+]
C3=[g+bd]
C4=[ac+e<]
C5=[b>df+<]
C6=[c+eg+]
C7=[>df+a<]

vn=v28
vs=v14
vb=v36

CA1=${vn} ${C1}
CA1s=${vs} ${C1}${vn}
CA1b=${vb} ${C1}${vn}

CB1=${vn} ${C2}
CB1s=${vs} ${C2}${vn}
CB1b=${vb} ${C2}${vn}

CC1=${vn} ${C2}
CC1s=${vs} ${C2} ${vn}
CC1b=${vb} ${C2} ${vn}
CC2=${vn} ${C1}
CC2s=${vs} ${C1} ${vn}
CC2b=${vb} ${C1} ${vn}
CD1=${vn} [f+a]
CD2=${vn} ${C1}
CD3=${vn} [f+a>c+]

A=${C1}${C1s}${C1s}${C1}${C1s}${C1s} ${C1}${C1s}${C1s}${C1}${C1s}${C1s}${C1b}${C1s}${C1b}${C1s}
B=${C2}${C2s}${C2s}${C2}${C2s}${C2s} ${C2}${C2s}${C2s}${C2}${C2s}${C2s}${C2b}${C2s}${C2b}${C2s}
A=${CA1}${CA1s}${CA1s}${CA1}${CA1s}${CA1s} ${CA1}${CA1s}${CA1s}${CA1}${CA1s}${CA1s}${CA1b}${CA1s}${CA1b}${CA1s}
B=${CB1}${CB1s}${CB1s}${CB1}${CB1s}${CB1s} ${CB1}${CB1s}${CB1s}${CB1}${CB1s}${CB1s}${CB1b}${CB1s}${CB1b}${CB1s}
C=${CC1}${CC1s}${CC1s}${CC1}${CC1s}${CC1s} ${CC2}${CC2s}${CC2s}${CC2}${CC2s}${CC2s}${CC2b}${CC2s}${CC2b}${CC2s}
D=${CD1}r${CD1}r rr ${CD1}r${CD1}r rr ${CD1}r${CD2}r rr ${CD3}r${CD3}r${CD3}r${CD3}^^r
ABAB
@c[a,8]
ABABAB
C
l8
D
//erer rr erer rr erer rr ererere^^r

