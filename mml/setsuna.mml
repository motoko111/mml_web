// Noise
// @0 短周期ノイズ
// @1 長周期ノイズ
@[noise]
t307 l4 o4 q90 v50 @1 @e[0,0.1,1.0,0.01] @m0
 /* hihat close */
h=@1 v20 o6 q90 @v[15] @p[0] @e[0.01,0.1,0.01,0] a
 /* hihat close */
H=@1 v20 o4 q90 @v[15] @p[0] @e[0.01,0.1,0.01,0] a
 /* hihat open */
n=@1 v40 o6 q90 @v[15] @p[0] @e[0.01,0.1,0.6,0.4] a
/* crash (simbal) */
c=@1 v30 o6 q90 @v[15] @p[0] @e[0.01,0.1,1.0,1.0] a
/*snare*/
s=@1 v30 o4 q90 @v[15] @p[0] @e[0.01,0.3,0.1,0.1] a
/*kick*/
k=@1 v60 o2 q90 @v[15] @p[0] @e[0.01,0.3,0.1,0] a
/*clap*/
C=@1 v30 o4 q90 @p[0] @v[15,15,15,0,0] @e[0.01,0.1,0.01,0] b

/:r:/16
/:
l4
hHhH hHhH hHhH hHhH 
hHhH hHhH hHhH hHhH 
hHhH hHhH hHhH hHhH 
hHhH hHhH hHhH hHhH 
hHhH hHhH hHhH hHhH 
