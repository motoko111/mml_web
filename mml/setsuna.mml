//l4 o4 q90 v5 @0 @e[0,0.4,1.0,0.5] @m0
t305
l4 q90
rr
C1^ ^^ c+^ e^ C1^ ^^ c+^ e^ 
C1^ ^^ e^ f+^ C1^ ^^ e^ f+^
C1^ ^^ c+^ e^ C1^ ^^ c+^ e^ 
C1^ ^^ f+^ a^ b^ a^ f+^ e^
C1^ ^^ c+^ e^ C1^ ^^ e^ f+^
C1^ ^^ e^ g+^ c+^ e^ f+^ g+^
C1^ ^^ e^ f+^ C1^ ^^ f+^ g+^
@c[a,1,0,0]
f+
@c[a,32,0,2.0]
f+f+f+f+f+f+f+f+f+f+f+f+f+f+r
@c[a]

t307
:/2
